@model ASP.NETCore_Lab_07.Models.SanPhamVM

@{
    ViewData["Title"] = "Thêm Sản Phẩm";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Thêm Mới Sản Phẩm</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <!-- Bắt buộc phải có enctype="multipart/form-data" để upload ảnh -->
                    <form asp-action="Create" enctype="multipart/form-data" method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- Tên sản phẩm (TenSP) -->
                        <div class="form-group mb-3">
                            <label asp-for="TenSP" class="font-weight-bold">Tên sản phẩm</label>
                            <input asp-for="TenSP" class="form-control" placeholder="Nhập tên sản phẩm..." />
                            <span asp-validation-for="TenSP" class="text-danger"></span>
                        </div>

                        <!-- Đơn giá (DonGia) -->
                        <div class="form-group mb-3">
                            <label asp-for="DonGia" class="font-weight-bold">Đơn giá</label>
                            <input asp-for="DonGia" type="number" step="0.01" class="form-control" placeholder="0.00" />
                            <span asp-validation-for="DonGia" class="text-danger"></span>
                        </div>

                        <!-- Loại sản phẩm (MaLoai) -->
                        <div class="form-group mb-3">
                            <label asp-for="MaLoai" class="font-weight-bold">Loại sản phẩm</label>
                            <!-- Sử dụng ViewBag.MaLoai đã được truyền từ Controller -->
                            <select asp-for="MaLoai" class="form-control" asp-items="ViewBag.MaLoai">
                                <option value="">-- Vui lòng chọn loại sản phẩm --</option>
                            </select>
                            <span asp-validation-for="MaLoai" class="text-danger"></span>
                        </div>

                        <!-- Hình ảnh (Anh) -->
                        <div class="form-group mb-4">
                            <label asp-for="Anh" class="font-weight-bold">Hình ảnh sản phẩm</label>
                            <input asp-for="Anh" type="file" class="form-control-file border p-2 w-100" accept="image/*" />
                            <span asp-validation-for="Anh" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <button type="submit" class="btn btn-success">
                                Lưu Sản Phẩm
                            </button>
                            <a asp-action="Index" class="btn btn-secondary ml-2">Quay Lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Script hỗ trợ Validate trực tiếp trên Client (Trình duyệt) -->
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}