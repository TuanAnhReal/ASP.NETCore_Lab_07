@model ASP.NETCore_Lab_07.Models.SanPhamVM

@{
    ViewData["Title"] = "Sửa Sản Phẩm";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">Cập Nhật Sản Phẩm</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <form asp-action="Edit" enctype="multipart/form-data" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- Dữ liệu ẩn quan trọng -->
                        <input type="hidden" asp-for="MaSP" />
                        <input type="hidden" asp-for="AnhCu" />

                        <div class="form-group mb-3">
                            <label asp-for="TenSP" class="font-weight-bold">Tên sản phẩm</label>
                            <input asp-for="TenSP" class="form-control" />
                            <span asp-validation-for="TenSP" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="DonGia" class="font-weight-bold">Đơn giá</label>
                            <input asp-for="DonGia" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="DonGia" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="MaLoai" class="font-weight-bold">Loại sản phẩm</label>
                            <select asp-for="MaLoai" class="form-control" asp-items="ViewBag.MaLoai"></select>
                            <span asp-validation-for="MaLoai" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label class="font-weight-bold">Hình ảnh hiện tại</label>
                            <div class="mb-2">
                                @if (!string.IsNullOrEmpty(Model.AnhCu))
                                {
                                    <img src="~/images/@Model.AnhCu" alt="Ảnh hiện tại" style="width: 150px;" class="img-thumbnail" />
                                }
                                else
                                {
                                    <span class="text-muted">Chưa có ảnh</span>
                                }
                            </div>
                            <label asp-for="Anh" class="font-weight-bold">Chọn ảnh mới (Bỏ trống nếu giữ nguyên)</label>
                            <input asp-for="Anh" type="file" class="form-control-file border p-2 w-100" accept="image/*" />
                            <span asp-validation-for="Anh" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <button type="submit" class="btn btn-warning font-weight-bold">
                                Lưu Thay Đổi
                            </button>
                            <a asp-action="Index" class="btn btn-secondary ml-2">Quay Lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}