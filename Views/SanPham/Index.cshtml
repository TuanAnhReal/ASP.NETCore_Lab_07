@model IEnumerable<ASP.NETCore_Lab_07.Models.SanPham>

@{
    ViewData["Title"] = "Danh sách Sản phẩm";
}

<div class="container mt-4">
    <h2 class="mb-3">Danh sách Sản phẩm</h2>

    <!-- Chỉ Admin mới thấy nút Thêm mới -->
    @if (User.IsInRole("Admin"))
    {
        <p>
            <a asp-action="Create" class="btn btn-primary font-weight-bold">+ Thêm mới sản phẩm</a>
        </p>
    }

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="thead-dark">
                <tr class="text-center">
                    <th>Hình ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Đơn giá</th>
                    <th>Loại sản phẩm</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th>Hành động</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(item.Anh))
                            {
                                <img src="~/images/@item.Anh" alt="@item.TenSP" style="width: 80px; height: 80px; object-fit: cover;" class="img-thumbnail" />
                            }
                            else
                            {
                                <span class="text-muted">Chưa có ảnh</span>
                            }
                        </td>
                        <td class="align-middle">@item.TenSP</td>
                        <td class="align-middle text-right">@item.DonGia.ToString("N0") VNĐ</td>
                        <td class="align-middle">@item.LoaiSP.TenLoai</td>

                        @if (User.IsInRole("Admin"))
                        {
                            <td class="align-middle text-center">
                                <a asp-action="Edit" asp-route-id="@item.MaSP" class="btn btn-sm btn-warning">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.MaSP" class="btn btn-sm btn-danger">Xóa</a>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Nút Phân trang -->
    <div class="d-flex justify-content-center mt-3">
        <nav>
            <ul class="pagination">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>