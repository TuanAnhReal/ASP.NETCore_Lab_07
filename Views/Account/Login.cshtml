@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">Đăng Nhập Hệ Thống</h4>
                </div>
                <div class="card-body p-4">
                    <!-- Khu vực hiển thị thông báo lỗi (sai tài khoản/mật khẩu) -->
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-0" })
                        </div>
                    }

                    <!-- Form đăng nhập -->
                    <form asp-controller="Account" asp-action="Login" method="post">
                        <div class="form-group mb-3">
                            <label class="font-weight-bold">Email</label>
                            <!-- Tên thẻ input (name="email") phải khớp chính xác với tham số trong Controller -->
                            <input type="email" name="email" class="form-control" required placeholder="Nhập email của bạn..." />
                        </div>

                        <div class="form-group mb-4">
                            <label class="font-weight-bold">Mật khẩu</label>
                            <input type="password" name="password" class="form-control" required placeholder="Nhập mật khẩu..." />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 font-weight-bold">
                            Đăng nhập
                        </button>
                    </form>
                </div>
                <div class="card-footer text-center bg-light">
                    Chưa có tài khoản? <a asp-action="Register" class="text-primary font-weight-bold">Đăng ký ngay</a>
                </div>
            </div>
        </div>
    </div>
</div>